# CloudHawk Environment Configuration
# Copy to .env and fill in all required values before running.
# Lines marked REQUIRED must be set — the containers will refuse to start without them.

# ── App ────────────────────────────────────────────────────────────────────
GITHUB_REPOSITORY=vatshariyani/cloudhawk
CLOUDHAWK_PORT=5000
CLOUDHAWK_DOMAIN=cloudhawk.local

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
CLOUDHAWK_SECRET_KEY=

# ── AWS (REQUIRED) ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Azure (optional) ───────────────────────────────────────────────────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── GCP (optional) ─────────────────────────────────────────────────────────
# Path on the HOST to your GCP service account JSON key
GCP_CREDENTIALS_PATH=

# ── Database (REQUIRED) ────────────────────────────────────────────────────
POSTGRES_DB=cloudhawk
POSTGRES_USER=cloudhawk
# REQUIRED — choose a strong password
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# ── Redis (REQUIRED) ───────────────────────────────────────────────────────
REDIS_PORT=6379
# REQUIRED — choose a strong password
REDIS_PASSWORD=

# ── Nginx (production only) ────────────────────────────────────────────────
NGINX_PORT=80
NGINX_SSL_PORT=443
# REQUIRED in production — paths to your TLS certificate and key on the HOST
SSL_CERT_PATH=
SSL_KEY_PATH=
